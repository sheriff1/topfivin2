{
  "name": "topfivin2",
  "version": "1.0.0",
  "description": "TopFivin2 - NBA Stats & Rankings Platform",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "prepare": "husky"
  },
  "lint-staged": {
    "backend/**/*.{js,cjs}": [
      "prettier --write",
      "backend/node_modules/.bin/eslint --fix"
    ],
    "frontend/**/*.{js,jsx}": [
      "prettier --write",
      "frontend/node_modules/.bin/eslint --fix --config frontend/eslint.config.cjs"
    ],
    "frontend/**/*.{html,css}": "prettier --write",
    "*.{json,md,yml,yaml}": "prettier --write"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0"
  },
  "pnpm": {
    "overrides": {
      "picomatch@2": ">=2.3.2",
      "picomatch@4": ">=4.0.4",
      "yaml@2": ">=2.8.3",
      "path-to-regexp": ">=8.4.0",
      "brace-expansion": ">=5.0.5"
    }
  }
}
