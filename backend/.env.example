# ──────────────────────────────────────────────────────────────────────────────
# NBA Stats Dashboard — Backend Environment
# Copy this file: cp backend/.env.example backend/.env
# ──────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5001
NODE_ENV=development

# CORS origin for the frontend dev server
FRONTEND_URL=http://localhost:3000

# ── Database ──────────────────────────────────────────────────────────────────
# Local development uses individual DB_* vars (no DATABASE_URL needed).
# Production (Railway) uses DATABASE_URL — set that in backend/.env.production.
#
# macOS Homebrew: DB_USER must match your system username — run: whoami
# Linux / Docker: typically "postgres"
DB_HOST=localhost
DB_PORT=5432
DB_USER=your_db_username
DB_PASSWORD=
DB_NAME=nba_stats

# ── Redis ─────────────────────────────────────────────────────────────────────
# Local Redis with no auth — leave REDIS_PASSWORD blank
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── App ───────────────────────────────────────────────────────────────────────
# NBA season year used by fetch / derive / rankings scripts
CURRENT_SEASON=2025

