# ============================================================================
# Environment Variables Configuration Template
# ============================================================================
# Copy this file to .env and fill in actual values for your environment
# 
# REQUIRED: Variables marked [REQUIRED] must be set or app will fail to start
# OPTIONAL: Variables marked [OPTIONAL] have sensible defaults
# ============================================================================

# ============================================================================
# Server Configuration
# ============================================================================
# [OPTIONAL] Server port (default: 5000)
PORT=5001

# [OPTIONAL] Node environment: development|test|production (default: development)
NODE_ENV=development

# [OPTIONAL] Frontend URL for CORS configuration (default: undefined)
# Set this in production to enable CORS from your frontend domain
FRONTEND_URL=http://localhost:3000

# ============================================================================
# Database Configuration
# ============================================================================
# CHOOSE ONE METHOD:
#   Method 1: DATABASE_URL (PostgreSQL connection string)
#   Method 2: Individual variables (DB_HOST, DB_PORT, DB_USER, DB_PASSWORD, DB_NAME)
#
# [REQUIRED] One of the methods above must be configured
# DATABASE_URL example: postgresql://user:password@localhost:5432/nba_stats
DATABASE_URL=

# [OPTIONAL] Individual database variables (if not using DATABASE_URL)
# These default to: host=localhost, port=5432, user=postgres, db=nba_stats
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=nba_stats

# ============================================================================
# Redis Cache Configuration
# ============================================================================
# CHOOSE ONE METHOD:
#   Method 1: REDIS_URL (Redis connection string)
#   Method 2: Individual variables (REDIS_HOST, REDIS_PORT, optional REDIS_PASSWORD)
#
# [REQUIRED] One of the methods above must be configured
# REDIS_URL example: redis://:password@localhost:6379
REDIS_URL=

# [OPTIONAL] Individual Redis variables (if not using REDIS_URL)
# These default to: host=localhost, port=6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ============================================================================
# Application Configuration
# ============================================================================
# [OPTIONAL] Current NBA season for queries (default: 2025)
CURRENT_SEASON=2025

